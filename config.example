# Praxis CLI Configuration
# Copy this file to ~/.config/praxis/config and fill in your values

# Praxis Webapp Backend API URL
# For local development: http://localhost:3001
# For production: Your Railway/Heroku URL
PRAXIS_API_URL=http://localhost:3001

# Supabase Configuration
# Get these from your Supabase project settings
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
PRAXIS_SUPABASE_URL=https://your-project.supabase.co
PRAXIS_SUPABASE_ANON_KEY=your-anon-key-here

# Note: The CLI uses the anon key (not service_role) for security
# since it runs on the client side.
